{
  "name": "@currentdao/contracts",
  "version": "1.0.0",
  "description": "Smart contracts for CurrentDAO with comprehensive AML compliance",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --outDir dist",
    "build:watch": "tsc --outDir dist --watch",
    "test": "jest",
    "test:aml": "jest tests/aml",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom='contracts/**/*.ts' --collectCoverageFrom='!**/*.d.ts'",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "deploy:aml": "ts-node scripts/deploy_aml.ts",
    "clean": "rm -rf dist coverage node_modules"
  },
  "keywords": ["ethereum", "smart-contracts", "aml", "compliance"],
  "author": "CurrentDAO",
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
